# SnapRec debe desplegarse en la raiz de un subdominio dedicado.
# Sustituye el dominio y las rutas de certificados antes de habilitarlo.

server {
    listen 80;
    server_name rec.tudominio.com;
    return 308 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name rec.tudominio.com;

    ssl_certificate     /etc/letsencrypt/live/rec.tudominio.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/rec.tudominio.com/privkey.pem;

    root /var/www/snaprec;
    index index.html;
    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    auth_basic           "SnapRec";
    auth_basic_user_file /etc/nginx/.htpasswd-snaprec;

    add_header Content-Security-Policy "default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'; form-action 'none'; script-src 'self'; style-src 'self'; font-src 'self'; img-src 'self' data: blob:; media-src 'self' blob:; worker-src 'self'; connect-src 'self'; manifest-src 'self'; trusted-types snaprec-worker; require-trusted-types-for 'script'; upgrade-insecure-requests" always;
    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options DENY always;
    add_header Referrer-Policy no-referrer always;
    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header Cross-Origin-Opener-Policy same-origin always;
    add_header Cross-Origin-Resource-Policy same-origin always;
    add_header Permissions-Policy "camera=(self), microphone=(self), display-capture=(self), geolocation=(), payment=(), usb=(), serial=(), bluetooth=(), hid=()" always;
    add_header Cache-Control "no-store" always;

    # El shell y el worker deben revalidarse para aplicar revocaciones y parches.
    location = / {
        try_files /index.html =404;
    }

    location = /index.html { }
    location = /sw.js { }

    location / {
        try_files $uri =404;
    }
}
